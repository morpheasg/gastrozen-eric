# GastroZen ERiC Microservice
# Kopiere zu .env und fuelle aus

# API-Schluessel fuer Authentifizierung (GastroZen -> Microservice)
API_SECRET_KEY=dein-geheimer-api-schluessel-hier

# ERiC SDK Pfade
ERIC_LIB_PATH=/app/eric_lib
ERIC_LOG_PATH=/app/logs

# ELSTER Konfiguration
HERSTELLER_ID=            # Von ELSTER nach Antrag
DATEN_LIEFERANT=GastroZen UG

# Test-Modus (true = Testmerker 700000004)
TEST_MODE=true

# Zertifikat-Verzeichnis
CERT_PATH=/app/certs

# Server
HOST=0.0.0.0
PORT=8000
